const express = require('express');
const yts = require('yt-search');
const ytdl = require('@distube/ytdl-core');
const app = express();
const PORT = process.env.PORT || 3000;

app.get('/api/search', async (req, res) => {
    const searchQuery = req.query.q;
    if (!searchQuery) {
        return res.status(400).json({ error: "Missing search query." });
    }

    try {
        console.log(`Searching for: ${searchQuery}`);
        const searchResults = await yts(searchQuery);
        const video = searchResults.videos[0]; // Lấy kết quả video chính xác đầu tiên

        if (!video) {
            return res.status(404).json({ error: "No videos found." });
        }

        console.log(`Found: ${video.title} - Generating proxy stream endpoint.`);
        
        // Tạo đường dẫn trung chuyển dữ liệu trực tiếp chạy qua máy chủ của bạn
        // Cơ chế này giúp Roblox kết nối an toàn mà không bị YouTube quét IP thiết bị
        const hostUrl = `${req.protocol}://${req.get('host')}`;
        const proxyStreamUrl = `${hostUrl}/api/play?url=${encodeURIComponent(video.url)}`;

        res.json({
            title: video.title,
            streamUrl: proxyStreamUrl
        });

    } catch (err) {
        console.log(`Search error: ${err.message}`);
        res.status(500).json({ error: err.message });
    }
});

// Cụm xử lý Proxy truyền âm thanh liên tục (Chunk Stream) chống lỗi chặn luồng (403)
app.get('/api/play', async (req, res) => {
    const videoUrl = req.query.url;
    if (!videoUrl) {
        return res.status(400).send("Missing video URL.");
    }

    try {
        // Thiết lập cấu hình User-Agent giả lập trình duyệt để YouTube không chặn dữ liệu
        const stream = ytdl(videoUrl, {
            quality: 'highestaudio',
            filter: 'audioonly',
            highWaterMark: 1 << 25,
            requestOptions: {
                headers: {
                    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
                }
            }
        });

        // Thiết lập Header phản hồi chuẩn định dạng âm thanh dòng chảy (Audio Stream) cho Roblox đọc
        res.setHeader('Content-Type', 'audio/mpeg');
        res.setHeader('Transfer-Encoding', 'chunked');

        // Truyền dữ liệu âm thanh thô liên tục (Pipe stream) trực tiếp về game
        stream.pipe(res);

        stream.on('error', (err) => {
            console.log(`Stream pipeline error: ${err.message}`);
            if (!res.headersSent) {
                res.status(500).send(err.message);
            }
        });

    } catch (err) {
        console.log(`Playback error: ${err.message}`);
        res.status(500).send(err.message);
    }
});

app.listen(PORT, () => {
    console.log(`Production API Server is actively listening on port ${PORT}`);
});
