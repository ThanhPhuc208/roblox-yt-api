local function createCtrlBtn(text, pos, size)
    local btn = Instance.new("TextButton")
    btn.Size = size or UDim2.new(0, 80, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 12
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = ControlsFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    return btn
end

PlayPauseBtn = createCtrlBtn("PAUSE", UDim2.new(0, 10, 0, 7))
LoopBtn = createCtrlBtn("LOOP: OFF", UDim2.new(0, 100, 0, 7))
VolumeDownBtn = createCtrlBtn("VOL -", UDim2.new(1, -140, 0, 7), UDim2.new(0, 60, 0, 35))
VolumeUpBtn = createCtrlBtn("VOL +", UDim2.new(1, -70, 0, 7), UDim2.new(0, 60, 0, 35))

local function executeStreamFetch(query)
    StatusLabel.Text = "Status: Connecting to API endpoint..."
    local targetUrl = PUBLIC_API_SERVER .. "/api/search?q=" .. game:GetService("HttpService"):UrlEncode(query)
    
    local success, response = pcall(function()
        return game:HttpGet(targetUrl)
    end)
    
    if success and response then
        local data = game:GetService("HttpService"):JSONDecode(response)
        if data and data.streamUrl then
            StatusLabel.Text = "Now Playing: " .. (data.title or query)
            AudioSource.SoundId = data.streamUrl
            AudioSource:Play()
            IsPlaying = true
            PlayPauseBtn.Text = "PAUSE"
        else
            StatusLabel.Text = "API Error: Stream URL could not be resolved for this track."
        end
    else
        StatusLabel.Text = "Network Error: Failed to reach the active API stream server."
    end
end

SearchBtn.MouseButton1Click:Connect(function()
    if SearchBar.Text ~= "" then
        executeStreamFetch(SearchBar.Text)
    end
end)

PlayPauseBtn.MouseButton1Click:Connect(function()
    if AudioSource.SoundId ~= "" then
        if IsPlaying then
            AudioSource:Pause()
            IsPlaying = false
            PlayPauseBtn.Text = "PLAY"
            StatusLabel.Text = "Status: Audio paused."
        else
            AudioSource:Resume()
            IsPlaying = true
            PlayPauseBtn.Text = "PAUSE"
            StatusLabel.Text = "Status: Resumed audio playback."
        end
    end
end)

LoopBtn.MouseButton1Click:Connect(function()
    IsLooped = not IsLooped
    AudioSource.Looped = IsLooped
    if IsLooped then
        LoopBtn.Text = "LOOP: ON"
        LoopBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
    else
        LoopBtn.Text = "LOOP: OFF"
        LoopBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    end
end)

VolumeUpBtn.MouseButton1Click:Connect(function()
    AudioSource.Volume = math.min(AudioSource.Volume + 0.1, 3)
end)

VolumeDownBtn.MouseButton1Click:Connect(function()
    AudioSource.Volume = math.max(AudioSource.Volume - 0.1, 0)
end)

CloseBtn.MouseButton1Click:Connect(function()
    AudioSource:Stop()
    ScreenGui:Destroy()
end)

